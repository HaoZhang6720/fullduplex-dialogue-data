# Copy this file to `.env` and fill in your credentials.
# The .env file is read by scripts/01_call_llm.py (via python-dotenv) and by run_pipeline.sh.

# Required: API key for the LLM provider.
LLM_API_KEY=sk-your-api-key-here

# Optional: base URL for OpenAI-compatible endpoints (Doubao Ark, vLLM, Azure, etc.).
# Leave unset to use the official OpenAI endpoint.
# Examples:
#   OpenAI (default):    (leave blank)
#   Doubao Ark:          https://ark.cn-beijing.volces.com/api/v3
#   Local vLLM:          http://localhost:8000/v1
LLM_BASE_URL=

# Required: model name to call. Must match a model your endpoint serves.
# Examples: gpt-4o, gpt-4o-mini, doubao-pro-32k, deepseek-chat, qwen2.5-72b-instruct
LLM_MODEL=gpt-4o

# Optional: concurrency for parallel API calls (default 8).
LLM_CONCURRENCY=8

# Optional: sampling parameters.
LLM_TEMPERATURE=1.0
LLM_MAX_TOKENS=4096
